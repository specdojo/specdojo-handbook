{
  "name": "specdojo devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "remoteUser": "node",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers-extra/features/yamllint:2": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/va-h/devcontainers-features/uv:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "ripgrep,fd-find,gh,fzf,yq,shellcheck,shfmt",
      "upgradePackages": false
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind",
    "source=${localEnv:HOME}/.codex,target=/home/node/.codex,type=bind"
  ],
  "postCreateCommand": "sudo npm install -g @openai/codex && if command -v fdfind >/dev/null 2>&1; then sudo ln -sf $(command -v fdfind) /usr/local/bin/fd; fi",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "streetsidesoftware.code-spell-checker",
        "mhutchie.git-graph",
        "openai.chatgpt",
        "github.copilot",
        "github.copilot-chat",
        "CucumberOpen.cucumber-official",
        "bierner.markdown-mermaid",
        "corschenzi.mermaid-graphical-editor",
        "redhat.vscode-yaml",
        "davidanson.vscode-markdownlint",
        "usernamehw.errorlens",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-remark",
        "yzhang.markdown-all-in-one",
        "vue.volar"
      ]
    }
  }
}
