{
  "name": "specdojo handbook devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "remoteUser": "root",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers-extra/features/yamllint:2": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {},
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "ripgrep,fd-find,gh,fzf,yq,shellcheck,shfmt",
      "upgradePackages": false
    }
  },
  "postCreateCommand": "npm install -g @fission-ai/openspec@latest && if command -v fdfind >/dev/null 2>&1; then ln -sf $(command -v fdfind) /usr/local/bin/fd; fi",

  "customizations": {
    "vscode": {
      "extensions": [
        "streetsidesoftware.code-spell-checker",
        "mhutchie.git-graph",
        "github.copilot",
        "github.copilot-chat",
        "CucumberOpen.cucumber-official",
        "bierner.markdown-mermaid",
        "corschenzi.mermaid-graphical-editor",
        "redhat.vscode-yaml",
        "davidanson.vscode-markdownlint",
        "usernamehw.errorlens",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-remark",
        "yzhang.markdown-all-in-one",
        "vue.volar"
      ]
    }
  }
}
