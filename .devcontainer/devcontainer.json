{
  "name": "specdojo devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "remoteUser": "node",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers-extra/features/yamllint:2": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/va-h/devcontainers-features/uv:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "ripgrep,fd-find,gh,fzf,yq,shellcheck,shfmt",
      "upgradePackages": false
    }
  },
  "mounts": [
    "source=specdojo-claude,target=/home/node/.claude,type=volume",
    "source=specdojo-claude-state,target=/home/node/.claude-state,type=volume",
    "source=specdojo-codex,target=/home/node/.codex,type=volume",
    "source=specdojo-copilot,target=/home/node/.copilot,type=volume",
    "source=specdojo-gh,target=/home/node/.config/gh,type=volume"
  ],
  "containerEnv": {
    "COPILOT_HOME": "/home/node/.copilot"
  },
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "streetsidesoftware.code-spell-checker",
        "mhutchie.git-graph",
        "openai.chatgpt",
        "github.copilot",
        "github.copilot-chat",
        "CucumberOpen.cucumber-official",
        "bierner.markdown-mermaid",
        "corschenzi.mermaid-graphical-editor",
        "redhat.vscode-yaml",
        "davidanson.vscode-markdownlint",
        "usernamehw.errorlens",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-remark",
        "yzhang.markdown-all-in-one",
        "vue.volar"
      ]
    }
  }
}
