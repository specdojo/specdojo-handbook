{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": ".tsbuild",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client", "vitepress/client"]
  },
  "references": [{ "path": "../../tools/docs/tsconfig.json" }],
  "include": ["./**/*.ts", "./**/*.mts"]
}
