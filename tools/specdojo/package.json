{
  "name": "specdojo",
  "version": "0.4.0",
  "description": "CLI for SpecDojo specification-driven execution workflows.",
  "license": "MIT",
  "author": "naoji3x",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specdojo/specdojo-handbook.git",
    "directory": "tools/specdojo"
  },
  "homepage": "https://github.com/specdojo/specdojo-handbook/tree/main/tools/specdojo",
  "bugs": {
    "url": "https://github.com/specdojo/specdojo-handbook/issues"
  },
  "keywords": [
    "specdojo",
    "cli",
    "specification",
    "project-management",
    "workflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "private": false,
  "type": "module",
  "bin": {
    "specdojo": "dist/specdojo.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "dev": "tsx src/specdojo.ts",
    "start": "node dist/specdojo.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
