{
  "name": "spec-dojo-handbook",
  "version": "0.1.0",
  "description": "A handbook for SpecDojo, a specification-driven development tool.",
  "license": "MIT",
  "author": "naoji3x",
  "private": true,
  "workspaces": [
    "tools/dojo"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "lint:md": "markdownlint '**/*.md'",
    "lint:md:fix": "markdownlint --fix '**/*.md'",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 5173",
    "docs:build:mermaid": "tsx tools/docs/src/gen-mermaid-svg.ts",
    "docs:rebuild:mermaid": "rm -f docs/public/mermaid/*.svg && npm run docs:build:mermaid",
    "docs:build": "vitepress build docs",
    "lint:fm": "remark \"docs/**/*.{md,mdx}\" --quiet --frail",
    "lint:yaml": "remark \"docs/**/*.{yaml,yml}\" --quiet --frail",
    "fmt:md": "tsx tools/docs/src/fmt-md.ts",
    "fmt:md:all": "tsx tools/docs/src/fmt-md.ts \"docs/**/*.{md,mdx}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/node": "^24.10.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lefthook": "^2.0.2",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-lint-frontmatter-schema": "^3.15.4",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.33.0"
  }
}
