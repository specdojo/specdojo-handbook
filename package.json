{
  "name": "spec-dojo-handbook",
  "version": "0.1.0",
  "description": "A handbook for SpecDojo, a specification-driven development tool.",
  "license": "MIT",
  "author": "naoji3x",
  "private": true,
  "workspaces": [
    "tools/specdojo"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "specdojo:build": "npm --workspace tools/specdojo run build",
    "lint:md": "markdownlint '**/*.md'",
    "lint:md:fix": "markdownlint --fix '**/*.md'",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 5173",
    "docs:build:mermaid": "tsx tools/docs/src/gen-mermaid-svg.ts",
    "docs:rebuild:mermaid": "rm -f docs/public/mermaid/*.svg && npm run docs:build:mermaid",
    "docs:build": "vitepress build docs",
    "lint:fm": "remark \"docs/**/*.{md,mdx}\" --quiet --frail",
    "validate:schema:bdd": "ajv --spec=draft2020 --strict=true -s docs/shared/schemas/bdd.schema.yaml -d \"docs/**/bdd-*.yaml\"",
    "validate:schema:esil": "ajv --spec=draft2020 --strict=true -s docs/shared/schemas/esil.schema.yaml -d \"docs/**/esil-*.yaml\"",
    "validate:schema:wbs": "ajv --spec=draft2020 --strict=true -s docs/shared/schemas/wbs.schema.yaml -d \"docs/**/wbs-*.yaml\"",
    "validate:schema:file": "tsx tools/docs/src/validate-yaml-schema.ts",
    "validate:schema": "npm run validate:schema:bdd && npm run validate:schema:esil && npm run validate:schema:wbs",
    "check": "npm run lint:md && npm run lint:fm && npm run validate:schema",
    "dc:ps": "docker ps --format \"table {{.Names}}\\t{{.Image}}\\t{{.Status}}\"",
    "dc:name": "bash -lc 'docker ps --format \"{{.Names}}\\t{{.Image}}\" | awk \"\\$2 ~ /^vsc-specdojo-handbook/ {print \\$1; exit}\"'",
    "dc:bash": "bash -lc 'name=$(docker ps --format \"{{.Names}}\\t{{.Image}}\" | awk \"\\$2 ~ /^vsc-specdojo-handbook/ {print \\$1; exit}\"); [ -n \"$name\" ] && docker exec -it \"$name\" bash -lc \"cd /workspaces/specdojo-handbook && exec bash\" || echo \"matching container not found\"'"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/node": "^24.10.1",
    "ajv": "^8.18.0",
    "ajv-cli": "^5.0.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lefthook": "^2.0.2",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "remark": "^15.0.1",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-lint-frontmatter-schema": "^3.15.4",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.33.0"
  }
}
