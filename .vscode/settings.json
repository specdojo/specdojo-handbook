  // ===== ファイル全体の共通設定 =====
  // 行末の余計な空白を削除
  "files.trimTrailingWhitespace": true,
  // ファイル末尾に必ず 1 行だけ改行を入れる
  "files.insertFinalNewline": true,
  // 2 行以上の余計な末尾改行は削除
  "files.trimFinalNewlines": true,

  // ===== Prettier 基本設定 =====
  // 可能なら Prettier をデフォルトフォーマッタに
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // 保存時に自動フォーマット
  "editor.formatOnSave": true,

  // Prettier 設定ファイル（.prettierrc 等）があるときだけ有効にするなら true
  // （プロジェクトごとにルールを変えたい場合に便利）
  "prettier.requireConfig": true,

  // VS Code統合ターミナルではワークスペースのCLIを直接実行できるようにする
  "terminal.integrated.env.linux": {
    "PATH": "${workspaceFolder}/node_modules/.bin:${env:PATH}"
  },
  "terminal.integrated.env.osx": {
    "PATH": "${workspaceFolder}/node_modules/.bin:${env:PATH}"
  },
  "terminal.integrated.env.windows": {
    "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}"
  },

  // ===== Markdown 専用設定 =====
  "markdown.extension.toc.levels": "2..6",
  "markdown.styles": [".vscode/markdown-preview.css"],
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,

    // markdownlint の自動修正も保存時に実行
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    },

    // 好み：Markdown は自動折り返しにしておくと読みやすい
    "editor.wordWrap": "on"
  },

  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,
  "yaml.format.enable": true,
  "yaml.schemas": {
    "./docs/specdojo/schemas/v1/bdd.schema.yaml": ["docs/ja/**/bdd-*.yaml"],
    "./docs/specdojo/schemas/v1/esil.schema.yaml": ["docs/ja/**/esil-*.yaml"],
    "./docs/specdojo/schemas/v1/sch-defaults.schema.yaml": ["docs/ja/**/sch-defaults*.yaml"],
    "./docs/specdojo/schemas/v1/sch-milestones.schema.yaml": ["docs/ja/**/sch-milestones*.yaml"],
    "./docs/specdojo/schemas/v1/sch-track.schema.yaml": ["docs/ja/**/sch-track-*.yaml"],
    "./docs/specdojo/schemas/v1/sch-config.schema.yaml": ["docs/ja/**/sch-config-*.yaml"],
    "./docs/specdojo/schemas/v1/sch-agent-overrides.schema.yaml": [
      "docs/ja/**/sch-agent-overrides-*.yaml"
    ],
    "./docs/specdojo/schemas/v1/wbs.schema.yaml": ["docs/ja/**/wbs-*.yaml"]
  },

  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },

  "files.associations": {
    "*.schema.yaml": "yaml",
    "*.instructions.md": "markdown"
  },
  "json.schemaDownload.enable": false,
  "chat.tools.terminal.autoApprove": {
    "/^python - <<'PY'\nfrom pathlib import Path\np = Path\\('/tmp/test-gh-step\\.sh'\\)\np\\.write_text\\('echo \"name=\\$\\(node -p \\\\\\\\\\\\\"require\\(\\\\'\\./tools/specdojo/package\\.json\\\\'\\)\\.name\\\\\\\\\\\\\"\\)\" >> \"\\$GITHUB_OUTPUT\"\\\\n'\\)\nprint\\(p\\.read_text\\(\\)\\)\nPY\nexport GITHUB_OUTPUT=/tmp/ghout && bash -e /tmp/test-gh-step\\.sh$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^set -e\ncd /workspaces/specdojo\nrg -n --hidden -g '!\\.git' -- 'docs/ja/specdojo/rulebooks\\|docs/ja/specdojo/rulebooks\\|\\\\\\.\\\\\\./rulebooks/' \\. \\| head -n 120 \\|\\| true$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
